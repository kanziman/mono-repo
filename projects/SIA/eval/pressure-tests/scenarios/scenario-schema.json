{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pressure Test Scenario Schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "dilemma_context": {
      "type": "string"
    },
    "skill_name": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["id", "text", "description"]
      },
      "minItems": 2
    },
    "rules_to_test": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pressure_factors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string"
          },
          "response": {
            "type": "string"
          }
        },
        "required": ["pattern", "response"]
      }
    },
    "timeout_ms": {
      "type": "integer"
    },
    "countdown_ms": {
      "type": "integer"
    },
    "countdown_warning": {
      "type": "string"
    }
  },
  "required": ["id", "title", "dilemma_context", "rules_to_test"]
}
